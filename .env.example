# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM (Groq) ───────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ── PDF + Email ──────────────────────────────
PDFSHIFT_API_KEY=
RESEND_API_KEY=
# Must be an address on a domain you've verified in Resend → Domains.
# onboarding@resend.dev (sandbox) does not deliver reliably to iCloud or other providers.
RESEND_FROM=you@yourdomain.com
YOUR_EMAIL=you@yourdomain.com

# ── Vercel ───────────────────────────────────
# Generate with: openssl rand -hex 16
CRON_SECRET=

# Public origin of the deployed FastAPI app — used to build absolute URLs
# in the weekly newsletter (hero photo <img src=…>, CTA download link).
# Local dev: http://localhost:8000. Prod: https://<your-app>.vercel.app.
APP_BASE_URL=http://localhost:8000

# ── Postgres (injected by Vercel–Neon integration in prod) ──
DATABASE_URL=
