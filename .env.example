# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM (Groq) ───────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ── Strava ───────────────────────────────────
# 1. Create app at https://www.strava.com/settings/api (callback domain: localhost)
# 2. Run: python3 scripts/strava_oauth.py to get the refresh token
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Max HR for the safety flag. Leave blank to disable flagging.
# Age-predicted = 220 - age. Measured max from a recent hard effort is more accurate.
USER_MAX_HR=194

# ── PDF + Email ──────────────────────────────
PDFSHIFT_API_KEY=
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
YOUR_EMAIL=

# ── Vercel ───────────────────────────────────
CRON_SECRET=

# ── Postgres (injected by Vercel–Neon integration in prod) ──
DATABASE_URL=
